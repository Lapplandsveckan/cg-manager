{
  "private": true,
  "name": "cg-manager",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "yarn workspace @lappis/cg-manager build",
    "package": "yarn workspace @lappis/cg-manager build && yarn workspace @cg-manager/server package",
    "start": "yarn workspace @lappis/cg-manager build && yarn workspace @cg-manager/server start",
    "lint": "yarn workspaces run lint",
    "lint:fix": "yarn workspaces run lint:fix",
    "format": "yarn workspaces run format",
    "format:check": "yarn workspaces run format:check",
    "tsc": "yarn workspaces run tsc"
  },
  "resolutions": {
    "strip-ansi": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4",
    "eslint-plugin-react-hooks": "^5",
    "globals": "^14.0.0",
    "prettier": "^3.8.3",
    "typescript": "^4.9.5",
    "typescript-eslint": "^8"
  }
}
